{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "kubernetes": {
    "fileMatch": [
      "\\.yaml$"
    ]
  },
  "flux": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ]
  },
  "assignees": [
    "druwan"
  ],
  "labels": [
    "deps"
  ],
  "reviewers": [
    "druwan"
  ],
  "packageRules": [
    {
      "description": "Only allow proper semver tags for LinuxServer/qBittorrent",
      "matchPackageNames": [
        "ghcr.io/linuxserver/qbittorrent"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)-r\\d+-ls(?<build>\\d+)$"
    },
    {
      "description": "Enable OCI Helm chart updates for Seerr",
      "matchDatasources": [
        "oci"
      ],
      "matchManagers": [
        "helm"
      ],
      "extractVersion": "^(?<version>\\d+\\.\\d+\\.\\d+)$",
      "versioning": "semver"
    }
  ]
}
